{
  "name": "postcss-custom-prop-sorting",
  "version": "4.1.0",
  "description": "Adds custom properties to the start of a declaration block and sorts them.",
  "license": "MPL-2.0",
  "author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.llc)",
  "repository": {
    "type": "git",
    "url": "https://github.com/castastrophe/postcss-custom-prop-sorting.git"
  },
  "bugs": {
    "url": "https://github.com/castastrophe/postcss-custom-prop-sorting/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "main": "index.js",
  "files": [
    "index.d.ts"
  ],
  "scripts": {
    "changeset": "changeset",
    "coverage": "c8 yarn test",
    "format": "prettier-package-json --write && prettier --write \"**/*.{js,json,md,yml}\"",
    "postinstall": "husky || true",
    "lint": "prettier --check \"**/*.{js,json,md,yml}\"",
    "prepack": "yarn types && pinst --disable",
    "postpack": "pinst --enable",
    "prepare": "husky",
    "release": "changeset publish",
    "test": "ava",
    "types": "tsc"
  },
  "types": "index.d.ts",
  "peerDependencies": {
    "postcss": "^8.4.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.0",
    "ava": "^8.0.0",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "pinst": "^3.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-package-json": "^2.8.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "css",
    "custom properties",
    "plugin",
    "postcss",
    "sorting"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": [
    {
      "type": "github",
      "url": " https://github.com/sponsors/castastrophe"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/castastrophe"
    }
  ],
  "packageManager": "yarn@4.16.0"
}
